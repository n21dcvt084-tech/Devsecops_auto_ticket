# DevSecOps Auto Ticket v2 - sample environment only.
# Copy this file to .env for local testing and fill secrets locally.


# DefectDojo
DEFECTDOJO_BASE_URL=https://dojo.example.com
DEFECTDOJO_API_TOKEN=XXXXXX
DEFECTDOJO_FINDINGS_LIMIT=100
DEFECTDOJO_REQUEST_TIMEOUT_SECONDS=60

# Scheduler
SCHEDULER_INTERVAL_SECONDS=300
PROCESSING_CLAIM_TTL_SECONDS=1800

# Database
DATABASE_URL=postgresql+psycopg://devsecops:devsecops@postgres:5432/devsecops

# Project -> recipient mapping
PROJECT_EMAIL_MAPPING_FILE=config/project_mapping.json

# SMTP sender for ticket and notification emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=devsecops@example.com
SMTP_PASSWORD=XXXXXX
SMTP_FROM_EMAIL=DevSecOps Automation <devsecops@example.com>
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=30
SMTP_MAX_EMAILS_PER_MINUTE=30
SMTP_MAX_EMAILS_PER_HOUR=500
SMTP_MAX_ATTEMPTS=3
SMTP_RETRY_DELAY_SECONDS=60
SMTP_RETRY_BACKOFF_MULTIPLIER=2

# ManageEngine integration mode.
# email_fetch: backend sends email, ManageEngine fetches mailbox.
# api: backend calls ManageEngine API directly.
MANAGEENGINE_DELIVERY_MODE=email_fetch
MANAGEENGINE_DRY_RUN=true

# Public ticket-list link rendered in email_fetch notification emails.
MANAGEENGINE_PUBLIC_URL=https://manageengine.example.com

# API-only settings. They are ignored while delivery mode is email_fetch.
MANAGEENGINE_BASE_URL=https://manageengine.example.com
MANAGEENGINE_AUTH_TOKEN=XXXXXX
MANAGEENGINE_REQUEST_TIMEOUT_SECONDS=30
MANAGEENGINE_VERIFY_SSL=true
MANAGEENGINE_REQUESTER_NAME=administrator
MANAGEENGINE_REQUESTER_EMAIL=

# Keep these blank until the exact ManageEngine names are confirmed.
MANAGEENGINE_DEFAULT_GROUP=
MANAGEENGINE_DEFAULT_CATEGORY=
MANAGEENGINE_DEFAULT_SUBCATEGORY=
